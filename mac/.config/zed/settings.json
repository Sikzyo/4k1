{
  "diff_view_style": "split",
  "disable_ai": true,
  "format_on_save": "on",
  "prettier": {
    "allowed": false
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "icon_theme": "Material Icon Theme",
  "theme_overrides": {
    "Catppuccin Frappé": {
      "border.variant": "#303446",
      "border": "#303446"
    },
    "Catppuccin Latte": {
      "border.variant": "#EEF1F5",
      "border": "#EEF1F5"
    }
  },
  "ui_font_size": 14,
  "title_bar": {
    "show_onboarding_banner": false
  },
  "tab_bar": {
    "show": false
  },
  "scrollbar": {
    "show": "never"
  },
  "agent": {
    "dock": "left",
    "default_width": 300
  },
  "debugger": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right",
    "auto_fold_dirs": false,
    "default_width": 300,
    "starts_open": false,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "indent_guides": {
      "show": "never"
    }
  },
  "buffer_font_family": "Monaspace Neon Var",
  "buffer_font_size": 12,
  "gutter": {
    "min_line_number_digits": 0
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "lsp": {
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "GraphQL": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
