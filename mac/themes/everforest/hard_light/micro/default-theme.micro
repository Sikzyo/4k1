color-link default "#5C6A72,#FFFBEF"
color-link comment "#939F91"
color-link selection "#5C6A72,#F0F2D4"
color-link hlsearch "#FFFBEF,#DFA000"

color-link identifier "#3A94C5"
color-link identifier.class "#35A77C"
color-link identifier.var "#5C6A72"

color-link constant "#35A77C"
color-link constant.number "#DF69BA"
color-link constant.string "#8DA101"

color-link symbol "#F57D26"
color-link symbol.brackets "#939F91"
color-link symbol.tag "#3A94C5"

color-link type "#DFA000"
color-link type.keyword "#F85552"

color-link special "#DF69BA"
color-link statement "#DF69BA"
color-link preproc "#F57D26"

color-link underlined "#3A94C5"
color-link error "bold #F85552"
color-link todo "bold #DFA000"

color-link diff-added "#8DA101"
color-link diff-modified "#DFA000"
color-link diff-deleted "#F85552"

color-link gutter-error "#F85552"
color-link gutter-warning "#DFA000"

color-link scrollbar "#939F91"
color-link statusline "#5C6A72,#F8F5E4"
color-link tabbar "#5C6A72,#F2EFDF"
color-link indent-char "#EDEADA"
color-link line-number "#A6B0A0"
color-link current-line-number "#829181"

color-link cursor-line "#F8F5E4"
color-link color-column "#F8F5E4"
color-link type.extended "default"
